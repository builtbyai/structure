{
  "name": "structure-cli",
  "version": "0.1.0",
  "description": "Modern CLI framework inspired by Obsidian CLI and Claude Code",
  "main": "dist/cli/index.js",
  "bin": {
    "structure": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-esm src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "cli",
    "terminal",
    "tui",
    "agents",
    "skills",
    "hooks",
    "automation"
  ],
  "author": "Jalen Ward",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
