# Copy to .env and fill in the providers you plan to use.
# All keys are optional — Structure only requires a key for the provider you invoke.

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: admin key for usage/rate-limit reporting (falls back to ANTHROPIC_API_KEY)
ANTHROPIC_ADMIN_KEY=

# OpenAI / Codex (provider: openai)
OPENAI_API_KEY=your-openai-api-key

# Ollama (provider: ollama) — local, no key required
# Override the default endpoint if Ollama is not on localhost:11434
# OLLAMA_HOST=http://localhost:11434
